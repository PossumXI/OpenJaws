{
  "name": "openjaws",
  "version": "2.1.86",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "description": "OpenJaws flight-deck terminal coding cockpit with OpenCheek agents and Immaculate orchestration",
  "license": "MIT",
  "homepage": "https://possumx.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PossumXI/OpenJaws.git"
  },
  "bugs": {
    "url": "https://github.com/PossumXI/OpenJaws/issues"
  },
  "author": "PossumX <opensource@possumx.dev> (https://possumx.dev)",
  "main": "src/main.tsx",
  "scripts": {
    "build": "bun build --target=bun --outdir=dist src/main.tsx",
    "build:native": "bun scripts/build-native.ts",
    "jaws:dev": "bun run --cwd apps/jaws-desktop tauri:dev",
    "jaws:build": "bun run --cwd apps/jaws-desktop tauri:build",
    "jaws:manifest:test": "bun run --cwd apps/jaws-desktop manifest:test",
    "jaws:release:check": "bun run --cwd apps/jaws-desktop release:check",
    "jaws:mirror:check": "bun scripts/jaws-release-mirror-health.ts",
    "jaws:ui:build": "bun run --cwd apps/jaws-desktop build",
    "jaws:verify": "bun run --cwd apps/jaws-desktop verify",
    "jaws:soak": "bun run --cwd apps/jaws-desktop soak",
    "jaws:admin:bootstrap": "bun scripts/bootstrap-jaws-admin.ts",
    "jaws:local:admin:seed": "bun run --cwd apps/jaws-desktop local:admin:seed",
    "website:dev": "bun run --cwd website dev",
    "website:build": "bun scripts/build-website.ts",
    "website:api:test": "bun install --cwd website --frozen-lockfile && bun test website/lib/*.test.ts",
    "website:snapshot:generate": "bun scripts/generate-website-benchmark-snapshot.ts",
    "website:snapshot:check": "bun scripts/generate-website-benchmark-snapshot.ts --check",
    "website:verify": "bun run website:snapshot:check && bun run website:api:test && bun run website:build",
    "website:deploy:check": "bun scripts/deploy-qline-site.ts --check-live",
    "website:deploy:safe": "bun scripts/deploy-qline-site.ts --promote",
    "website:sharecard": "bun scripts/generate-qline-share-card.ts",
    "release:version": "bun scripts/print-release-version.ts",
    "release:asset": "bun scripts/build-release-asset.ts",
    "banner:export": "bun scripts/export-openjaws-banner.ts",
    "qmark:export": "bun scripts/export-q-mark.ts",
    "test": "bun scripts/run-unit-tests.ts",
    "test:coverage:scripts": "bun scripts/run-unit-tests.ts --scope scripts --coverage --min-line-coverage 15",
    "audit:knip": "bun scripts/run-knip-audit.ts",
    "verify:ci": "bun run audit:knip && bun run test:coverage:scripts && bun run test && bun run build && bun run website:verify",
    "verify:public": "bun run test && bun run build && bun run build:native && bun run website:verify",
    "verify:release": "bun run test && bun run build && bun run build:native && bun run website:verify && bun run system:check",
    "export:sft": "bun scripts/export-openjaws-sft.ts",
    "prepare:sft": "bun scripts/prepare-openjaws-sft.ts",
    "audit:sft": "bun scripts/audit-openjaws-sft.ts",
    "launch:q": "bun scripts/launch-q-train.ts",
    "q:bridgebench": "bun scripts/q-bridgebench.ts",
    "q:curriculum": "bun scripts/run-q-curriculum.ts",
    "q:hybrid": "bun scripts/run-q-hybrid-session.ts",
    "q:preflight": "bun scripts/q-preflight.ts",
    "q:soak": "bun scripts/q-soak-bench.ts",
    "q:terminalbench": "bun scripts/q-terminalbench.ts",
    "q:terminalbench:soak": "bun scripts/q-terminalbench.ts --soak --soak-cycles 3 --soak-duration-minutes 45",
    "q:receipt:sign": "bun scripts/sign-benchmark-receipt.ts",
    "roundtable:runtime": "bun scripts/roundtable-runtime.ts --json",
    "runtime:coherence": "bun scripts/runtime-coherence.ts --json",
    "personaplex:probe": "bun scripts/personaplex-probe.ts --json",
    "orchestration:guardrails": "bun scripts/agentic-orchestration-guardrails.ts --json",
    "service:routes": "bun scripts/service-route-health.ts --json",
    "apex:bridges": "bun scripts/apex-bridge-health.ts --json",
    "apex:bridges:start": "bun scripts/apex-bridge-health.ts --json --start-missing",
    "services:backend:test": "bun test services/cloudflare-hosted-q/worker.test.ts",
    "services:backend:deploy": "bunx wrangler deploy --config services/cloudflare-hosted-q/wrangler.toml",
    "discord:q:repair": "bun scripts/discord-agent-supervisor.ts repair --agent Q",
    "discord:viola:repair": "bun scripts/discord-agent-supervisor.ts repair --agent Viola",
    "discord:blackbeak:repair": "bun scripts/discord-agent-supervisor.ts repair --agent Blackbeak",
    "discord:tasks:install": "bun scripts/discord-agent-supervisor.ts install-tasks",
    "showcase:activity:sync": "bun scripts/sync-public-showcase-activity.ts --json",
    "showcase:copy:check": "bun scripts/check-public-showcase-copy.ts --json",
    "dispatch:q-route": "bun scripts/dispatch-q-route.ts",
    "process:q-routes": "bun scripts/process-q-routes.ts",
    "poll:q-route": "bun scripts/poll-q-route-result.ts",
    "q-route:contention": "bun scripts/q-route-contention-live.ts",
    "q-route:lease": "bun scripts/q-route-lease-live.ts",
    "q-route:assignment": "bun scripts/q-route-worker-assignment-live.ts",
    "q-route:remote-dispatch": "bun scripts/q-route-remote-dispatch-live.ts",
    "q-route:remote-completion": "bun scripts/q-route-remote-completion-live.ts",
    "deferred-launch:walkthrough": "bun scripts/deferred-launch-walkthrough.tsx",
    "deferred-launch:controls": "bun scripts/deferred-launch-controls-live.ts",
    "provider:probe": "bun scripts/provider-probe-live.ts",
    "onboarding:walkthrough": "bun scripts/onboarding-setup-walkthrough.tsx",
    "settings:walkthrough": "bun scripts/settings-walkthrough.tsx",
    "system:check": "bun scripts/system-check.ts"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.27.0",
    "@anthropic-ai/foundry-sdk": "^0.2.3",
    "@anthropic-ai/mcpb": "^2.1.2",
    "@anthropic-ai/sandbox-runtime": "^0.0.46",
    "@anthropic-ai/sdk": "^0.81.0",
    "@anthropic-ai/vertex-sdk": "^0.14.4",
    "@aws-sdk/client-bedrock": "^3.1022.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1022.0",
    "@aws-sdk/client-sts": "^3.1029.0",
    "@aws-sdk/credential-provider-node": "^3.972.29",
    "@azure/identity": "^4.13.1",
    "@commander-js/extra-typings": "^12.1.0",
    "@discordjs/voice": "^0.19.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@smithy/node-http-handler": "^4.5.1",
    "axios": "^1.7.0",
    "bidi-js": "^1.0.3",
    "blessed": "^0.1.81",
    "chalk": "^5.3.0",
    "chokidar": "^5.0.0",
    "color-diff-napi": "^0.0.1",
    "conf": "^12.0.0",
    "diff": "^8.0.4",
    "dotenv": "^16.4.5",
    "execa": "^9.5.0",
    "fflate": "^0.8.2",
    "ffmpeg-static": "^5.3.0",
    "find-up": "^7.0.0",
    "fs-extra": "^11.2.0",
    "fuse.js": "^7.3.0",
    "glob": "^10.4.0",
    "google-auth-library": "^10.6.2",
    "gradient-string": "^2.0.2",
    "highlight.js": "^11.11.1",
    "https-proxy-agent": "^7.0.5",
    "ignore": "^7.0.5",
    "ink": "^5.0.1",
    "is-online": "^10.0.0",
    "js-yaml": "^4.1.0",
    "jsonc-parser": "^3.3.1",
    "lodash-es": "^4.17.21",
    "marked": "^17.0.5",
    "modifiers-napi": "^0.0.1",
    "opusscript": "^0.1.1",
    "ora": "^8.0.1",
    "p-map": "^7.0.4",
    "picomatch": "^4.0.4",
    "prettier": "^3.3.0",
    "prism-media": "^1.3.5",
    "prompts": "^2.4.2",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^18.3.1",
    "react-reconciler": "0.33.0",
    "semver": "^7.6.3",
    "sharp": "^0.34.5",
    "shell-quote": "^1.8.3",
    "supports-hyperlinks": "^4.4.0",
    "tar": "^6.2.1",
    "tree-kill": "^1.2.2",
    "turndown": "^7.2.4",
    "tweetnacl": "^1.0.3",
    "undici": "^6.19.0",
    "update-notifier": "^7.0.0",
    "usehooks-ts": "^3.1.1",
    "vscode-jsonrpc": "^8.2.1",
    "ws": "^8.18.0",
    "xss": "^1.0.15",
    "yaml": "^2.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.14",
    "knip": "^6.4.1",
    "typescript": "^5.5.0"
  }
}
