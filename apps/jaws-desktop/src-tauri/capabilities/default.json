{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main JAWS Desktop window permissions.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "updater:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/openjaws",
          "sidecar": true,
          "args": ["--version"]
        }
      ]
    }
  ]
}
