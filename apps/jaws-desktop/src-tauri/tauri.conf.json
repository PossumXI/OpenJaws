{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JAWS",
  "version": "0.1.1",
  "identifier": "site.qline.jaws",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://127.0.0.1:5177",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "JAWS",
        "label": "main",
        "width": 1320,
        "height": 860,
        "minWidth": 960,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src 'self' https://qline.site https://iorch.net https://github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/openjaws"],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRCQzYwNjAxQjRGQTI5N0QKUldSOUtmcTBBUWJHUzJMcGZWMkpQQzBNZVZobUxackxuVXRPVThaamNBSkRycmlJaTRNd0hQcU0K",
      "endpoints": [
        "https://qline.site/api/jaws/{{target}}/{{arch}}/{{current_version}}",
        "https://iorch.net/api/jaws/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
