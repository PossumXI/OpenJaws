# OpenJaws - Telemetry Disabled
# These env vars disable all non-essential network traffic
DISABLE_TELEMETRY=1
OPENJAWS_DISABLE_NONESSENTIAL_TRAFFIC=1

# Apex workspace bridge
# OPENJAWS_APEX_ROOT=C:\path\to\apex-os-project
