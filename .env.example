# OpenJaws - Telemetry Disabled
# These env vars disable all non-essential network traffic
DISABLE_TELEMETRY=1
OPENJAWS_DISABLE_NONESSENTIAL_TRAFFIC=1

# OAuth / hosted login
# OPENJAWS_CUSTOM_OAUTH_URL=https://qline.site
# USER_TYPE=jaws
# USE_LOCAL_OAUTH=1
# CLAUDE_LOCAL_OAUTH_API_BASE=http://localhost:8000
# CLAUDE_LOCAL_OAUTH_APPS_BASE=http://localhost:4000
# CLAUDE_LOCAL_OAUTH_CONSOLE_BASE=http://localhost:3000
# OPENJAWS_OAUTH_CLIENT_ID=replace-with-your-local-client-id

# Apex workspace bridge
# OPENJAWS_APEX_ROOT=C:\path\to\apex-os-project
# OPENJAWS_APEX_ASGARD_ROOT=D:\cheeks\Asgard
# OPENJAWS_APEX_NOTIFICATIONS_ROOT=D:\cheeks\Asgard\Notifications
# OPENJAWS_APEX_ARGUS_ROOT=D:\cheeks\Asgard\argus
# OPENJAWS_APEX_WORKSPACE_API_URL=http://127.0.0.1:8797
# OPENJAWS_APEX_CHRONO_API_URL=http://127.0.0.1:8798
# OPENJAWS_APEX_BROWSER_API_URL=http://127.0.0.1:8799
# OPENJAWS_APEX_TENANT_GOVERNANCE_API_URL=http://127.0.0.1:3000
# OPENJAWS_APEX_TENANT_GOVERNANCE_MIRROR_FILE=docs/wiki/Apex-Tenant-Governance.json
# OPENJAWS_APEX_TRUST_LOCALHOST=0

# Discord Q / Viola agents
# Never paste live Discord tokens into chat, docs, commits, or command logs.
# Store the active bot token only in a local ignored `.env.local` or a secret manager.
# DISCORD_BOT_TOKEN=replace-with-discord-bot-token
# DISCORD_APPLICATION_ID=replace-with-application-id
# DISCORD_DEFAULT_GUILD_ID=replace-with-primary-guild-id
# DISCORD_OPERATOR_USER_ID=replace-with-founder-or-operator-user-id
# DISCORD_TRAINER_USER_IDS=comma-separated-trainer-user-ids
# DISCORD_AGENT_PROFILE=viola
# DISCORD_AGENT_TEXT_CHANNEL=dev_support
# DISCORD_AGENT_VOICE_CHANNEL=viola-lounge
# DISCORD_Q_VOICE_PROVIDER=system
# DISCORD_Q_PUBLIC_LEDGER_SYNC=1
# DISCORD_Q_APPEND_ONLY_AUDIT=1
# DISCORD_Q_MAX_ATTACHMENTS=5
# DISCORD_Q_MAX_ATTACHMENT_BYTES=8388608

# PersonaPlex / Moshi voice backend
# Canonical local contract: 127.0.0.1:8998 for the OpenJaws Discord voice bridge.
# Override only when a different PersonaPlex/Moshi runtime is intentionally staged.
# PERSONAPLEX_URL=ws://127.0.0.1:8998/api/chat
# PERSONAPLEX_HOST=127.0.0.1
# PERSONAPLEX_PORT=8998
# PERSONAPLEX_SSL=0
# PERSONAPLEX_VOICE=viola
